{
  "mcpServers": {
    "chub": {
      "command": "chub",
      "args": ["mcp"],
      "cwd": "."
    }
  },
  "permissions": {
    "allow": [
      "Bash(chub *)",
      "mcp__chub__chub_search",
      "mcp__chub__chub_get",
      "mcp__chub__chub_list",
      "mcp__chub__chub_context",
      "mcp__chub__chub_annotate",
      "mcp__chub__chub_feedback",
      "mcp__chub__chub_pins"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/chub-freshness-check.sh"
          }
        ]
      }
    ]
  }
}
