{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/chub-freshness-check.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "chub": {
      "args": [
        "mcp"
      ],
      "command": "chub",
      "cwd": "."
    }
  },
  "permissions": {
    "allow": [
      "Bash(chub *)",
      "Bash(cargo *)",
      "mcp__chub__chub_search",
      "mcp__chub__chub_get",
      "mcp__chub__chub_list",
      "mcp__chub__chub_context",
      "mcp__chub__chub_annotate",
      "mcp__chub__chub_feedback",
      "mcp__chub__chub_pins",
      "mcp__chub__chub_track",
      "Bash(entire *)"
    ],
    "deny": [
      "Read(./.entire/metadata/**)"
    ]
  }
}
